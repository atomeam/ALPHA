# Sample .env for ProposalsWatcher
# Copy to .env and fill in your values

# Notion API (get from https://www.notion.so/my-integrations)
NOTION_API_KEY=secret_your_api_key_here

# Proposals DB ID (from Notion database URL)
PROPOSALS_DB_ID=625bc5ae232446bb8f1861d4614278e1

# Poll interval in milliseconds (default: 5000)
POLL_INTERVAL_MS=5000

# Set to 'true' to use mock responses only
USE_MOCK=false