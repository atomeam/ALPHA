{
  "integrations": [
    {
      "name": "stripe",
      "type": "api",
      "enabled": true,
      "baseUrl": "https://api.stripe.com/v1",
      "apiKeyEnvVar": "STRIPE_API_KEY",
      "metadata": {
        "description": "Payment processing",
        "version": "2023-10-16"
      }
    },
    {
      "name": "hubspot",
      "type": "api",
      "enabled": true,
      "baseUrl": "https://api.hubapi.com",
      "apiKeyEnvVar": "HUBSPOT_API_KEY",
      "headers": {
        "Content-Type": "application/json"
      },
      "metadata": {
        "description": "CRM and marketing automation",
        "version": "v3"
      }
    },
    {
      "name": "slack",
      "type": "api",
      "enabled": true,
      "baseUrl": "https://slack.com/api",
      "apiKeyEnvVar": "SLACK_BOT_TOKEN",
      "headers": {
        "Content-Type": "application/json"
      },
      "metadata": {
        "description": "Team communication",
        "version": "1.0.0"
      }
    },
    {
      "name": "sentry",
      "type": "api",
      "enabled": false,
      "baseUrl": "https://sentry.io/api/0",
      "apiKeyEnvVar": "SENTRY_AUTH_TOKEN",
      "metadata": {
        "description": "Error monitoring and tracking",
        "version": "0.0.1"
      }
    },
    {
      "name": "stripe-mcp",
      "type": "mcp",
      "enabled": false,
      "mcpServerUrl": "http://localhost:3100",
      "mcpTools": ["stripe_validate_charge", "stripe_list_payments", "stripe_get_customer"],
      "metadata": {
        "description": "Stripe MCP for payment scope voting",
        "scopeBinding": "payments"
      }
    },
    {
      "name": "filesystem-mcp",
      "type": "mcp",
      "enabled": true,
      "mcpServerUrl": "http://localhost:3100",
      "mcpTools": ["read_file", "write_file", "list_directory"],
      "metadata": {
        "description": "MCP server for filesystem operations"
      }
    }
  ]
}