{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@alpha/core": ["packages/alpha-core/src/index.ts"],
      "@alpha/logger": ["packages/logger/src/index.ts"],
      "@alpha/mcp-core": ["packages/mcp-core/src/index.ts"],
      "@alpha/nexus-core": ["packages/nexus-core/src/index.ts"],
      "@alpha/permissions": ["packages/permissions/src/index.ts"]
    },
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
