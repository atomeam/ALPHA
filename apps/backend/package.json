    "@google/genai": "^1.29.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "vite": "^6.2.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.6"
  }
