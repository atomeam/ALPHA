{
  "name": "@alpha/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Alpha bridge — lightweight HTTP relay on :8090. Full PowerShell bridge ships in Phase 6.",
  "main": "src/index.ts",
  "scripts": {
    "build": "wrangler types && tsc -p tsconfig.json --noEmit",
    "dev": "wrangler dev --port 8090",
    "deploy": "wrangler deploy",
    "start": "wrangler dev --port 8090",
    "lint": "echo 'bridge: ESLint skipped (ignored in root config until Phase 6)'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx vitest run",
    "dev:local": "node --import tsx src/server.ts"
  },
  "dependencies": {
    "@alpha/logger": "workspace:*",
    "hono": "^4.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.8.2",
    "wrangler": "^3.114.17",
    "vitest": "^3.0.0"
  }
}
