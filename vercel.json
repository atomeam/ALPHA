{
  "version": 2,
  "framework": "express",
  "builds": [
    {
      "src": "apps/backend/dist/server.cjs",
      "use": "@vercel/node"
    }
  ],
  "install": "npm install --include=devDependencies",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/backend/dist/server.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "apps/backend/dist/server.cjs"
    }
  ]
}