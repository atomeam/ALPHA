{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/dist/server.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/backend/dist/server.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "apps/backend/dist/server.cjs"
    }
  ]
}