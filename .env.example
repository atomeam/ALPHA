# =============================================================================
# Alpha — example environment configuration
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Real .env files are git-ignored. Never commit real secrets.
# =============================================================================

# -------- Runtime --------
NODE_ENV=development
LOG_LEVEL=info

# -------- Ports --------
# Backend HTTP API
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0

# Frontend (Vite) dev server
FRONTEND_PORT=5173
FRONTEND_HOST=0.0.0.0

# Public URL the frontend uses to call the backend
VITE_API_BASE_URL=http://localhost:8080

# -------- Trust kernel --------
# Mode: "strict" (deny by default, only explicit grants accepted)
#       "audit" (allow with logging; use only in non-prod for migration work)
TRUST_MODE=strict

# Path or URL to the active grants registry (see docs/TRUST.md).
TRUST_GRANTS_PATH=./trust/grants.json

# Per-request signing key used by the trust kernel to issue scoped tokens.
TRUST_SIGNING_KEY=

# -------- Integrations (placeholders — only fill the ones you use) --------
AMPLITUDE_API_KEY=
GEMINI_API_KEY=
HUBSPOT_API_KEY=
LINEAR_API_KEY=
NOTION_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
SENTRY_DSN=
SLACK_BOT_TOKEN=
STRIPE_SECRET_KEY=
