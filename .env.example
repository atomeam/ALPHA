# ===========================================================================
# Alpha — root .env.example
#
# Copy to `.env` and fill in. `.env` is gitignored. Per-app .env files may
# also exist under apps/<name>/.env once those apps land in later phases.
#
# Trust rule: no key here is read passively. Every outbound call that uses
# any of these must go through packages/permissions (Grant check) once it
# exists in Phase 4.
# ===========================================================================

# ---------------------------------------------------------------------------
# apps/backend  (Node/Express on :8080)
# ---------------------------------------------------------------------------
PORT=8080
GIT_SHA=
SERVE_STATIC=false
FRONTEND_DIST_DIR=apps/frontend/dist

# Gemini (apps/backend → integrations/gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Neural Bridge (apps/backend → integrations/ollama)
NEURAL_BRIDGE_URL=http://localhost:11434

# Building banner (carried over from HomeBase)
HOMEBASE_BUILDING_LABEL=
HOMEBASE_BUILDING_BRANCH=
HOMEBASE_BUILDING_BASE=
HOMEBASE_BUILDING_PR=
HOMEBASE_BUILDING_PR_URL=

# ---------------------------------------------------------------------------
# apps/frontend  (Vite on :5173)
# ---------------------------------------------------------------------------
# (No client-side keys. Frontend never sees integration credentials.)
VITE_BACKEND_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# apps/bridge  (PowerShell, on :8090 — replaces old :8080 conflict)
# ---------------------------------------------------------------------------
BRIDGE_PORT=8090
RETROARCH_HOST=127.0.0.1
RETROARCH_PORT=55355
ATOMARCADE_ALLOW_HIGH_RISK=

# ---------------------------------------------------------------------------
# Integrations  (all on-demand, Grant-checked, no background pollers)
# ---------------------------------------------------------------------------
# Notion
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_AUTO_DB_ID=
NOTION_LOG_DB_ID=
NOTION_WEBHOOK_SECRET=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Sentry (DSN comes from env only — no hardcoded values in source)
SENTRY_DSN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# HubSpot
HUBSPOT_ACCESS_TOKEN=

# Amplitude
AMPLITUDE_API_KEY=

# Linear
LINEAR_API_KEY=
