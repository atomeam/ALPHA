# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# NOTE: This key is only used server-side (server.js). It is NOT exposed to the client bundle.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: optional override; defaults to gemini-2.5-flash.
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# PORT: server.js listen port. Defaults to 8080 (Cloud Run default).
PORT="8080"

# ATOMARCADE_NOTION_LOG_DB_ID: Notion DB id used by the Bridge for routing logs.
# Surfaced in /api/health as bridge.configured.
ATOMARCADE_NOTION_LOG_DB_ID=""

# GIT_SHA: optional override; otherwise server reads .git/HEAD at boot.
# In Cloud Run, set this at deploy time to the commit SHA.
GIT_SHA=""

# SERVE_STATIC: set to "true" to have server.js also serve the built ./dist directory.
# Used in production. In dev, vite serves the client and proxies /api to this server.
SERVE_STATIC="false"

# Building banner shown at the top of the app so the launcher lands on whatever is in progress.
HOMEBASE_BUILDING_LABEL="Tier 1 — server + health + tests"
HOMEBASE_BUILDING_BRANCH="alpha"
HOMEBASE_BUILDING_BASE="main"
HOMEBASE_BUILDING_PR="1"
HOMEBASE_BUILDING_PR_URL="https://github.com/atomeam/HomeBase-/pull/1"
