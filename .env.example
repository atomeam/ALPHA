# Aether Sovereign Engine Configuration
# Copy to .env and fill in your values

# ===========================================
# STRIPE - Payment Processing
# Get your keys from https://dashboard.stripe.com/apikeys
# ===========================================
STRIPE_API_KEY=

# ===========================================
# HUBSPOT - CRM
# Get your key from https://app.hubspot.com/settings/api-key
# ===========================================
HUBSPOT_API_KEY=

# ===========================================
# SLACK - Team Communication
# Create a bot at https://api.slack.com/apps
# ===========================================
SLACK_BOT_TOKEN=

# ===========================================
# SENTRY - Error Monitoring (optional)
# Get from https://sentry.io/settings/<org>/api-keys
# ===========================================
SENTRY_AUTH_TOKEN=

# ===========================================
# Legacy / Other
# ===========================================
GEMINI_API_KEY=

# ===========================================
# Victus Runtime Configuration
# ===========================================
NEURAL_BRIDGE_URL=http://localhost:8080
VICTUS_RUNTIME_URL=http://localhost:8080

# MCP Server (if using filesystem-mcp)
MCP_SERVER_URL=http://localhost:3100
