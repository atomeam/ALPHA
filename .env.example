# ===========================================================================
# Alpha — root .env.example
#
# Copy to `.env` and fill in. `.env` is gitignored. Per-app .env files may
# also exist under apps/<name>/.env once those apps land in later phases.
#
# Trust rule: no key here is read passively. Every outbound call that uses
# any of these must go through packages/permissions (Grant check) once it
# exists in Phase 4.
# ===========================================================================

# ---------------------------------------------------------------------------
# Trust kernel (packages/permissions, Phase 4)
# ---------------------------------------------------------------------------
# Default TTL (seconds) for the EphemeralGrant the kernel mints after a
# successful trust.check(). Must be > 0; ephemeral grants are never
# longer-lived than this. See docs/TRUST.md § 4.4.
TRUST_EPHEMERAL_TTL=60

# ---------------------------------------------------------------------------
# apps/backend  (Node/Express on :8080)
# ---------------------------------------------------------------------------
PORT=8080
GIT_SHA=
SERVE_STATIC=false

# Gemini (apps/backend → integrations/gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Neural Bridge (apps/backend → integrations/ollama)
NEURAL_BRIDGE_URL=http://localhost:11434

# Building banner (carried over from HomeBase)
HOMEBASE_BUILDING_LABEL=
HOMEBASE_BUILDING_BRANCH=
HOMEBASE_BUILDING_BASE=
HOMEBASE_BUILDING_PR=
HOMEBASE_BUILDING_PR_URL=

# ---------------------------------------------------------------------------
# apps/frontend  (Vite on :5173)
# ---------------------------------------------------------------------------
# (No client-side keys. Frontend never sees integration credentials.)
VITE_BACKEND_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# apps/bridge  (PowerShell, on :8090 — replaces old :8080 conflict)
# ---------------------------------------------------------------------------
BRIDGE_PORT=8090

# ---------------------------------------------------------------------------
# Cloudflare Workers (self-adaptive-app deployment)
# ---------------------------------------------------------------------------
# Account ID from Cloudflare dashboard → Workers & Pages → Overview
CLOUDFLARE_ACCOUNT_ID=

# API token: Workers > Create Token → Account: Workers:Edit, KV:Edit, Pages:Edit
CLOUDFLARE_API_TOKEN=

# Worker name (matches wrangler.toml name)
CLOUDFLARE_WORKER_NAME=self-adaptive-app

# Production route
CLOUDFLARE_PRODUCTION_ROUTE=alpha.atomeam.workers.dev/*

# KV namespaces (create via: wrangler kv:namespace create METRICS)
# Preview namespace for local/branch deploys
CLOUDFLARE_KV_METRICS_PREVIEW_ID=
# Production namespace
CLOUDFLARE_KV_METRICS_ID=

# Action queue (create via: wrangler queue create adaptive-actions)
CLOUDFLARE_QUEUE_ADAPTIVE_ACTIONS=

# Durable Object class (if using AssessmentBrain DO)
CLOUDFLARE_DO_ASSESSMENT_BRAIN=

# ---------------------------------------------------------------------------
# OpenHands Cloud (self-improvement loop)
# ---------------------------------------------------------------------------
# Get from: app.all-hands.dev → Settings → API Keys
OPENHANDS_CLOUD_API_KEY=

# Alpha self-improvement cycle tracking
ALPHA_LAST_CYCLE_AT=

# ---------------------------------------------------------------------------
# Integrations  (all on-demand, Grant-checked, no background pollers)
# ---------------------------------------------------------------------------
# Notion
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_AUTO_DB_ID=
NOTION_LOG_DB_ID=
NOTION_WEBHOOK_SECRET=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Sentry (DSN comes from env only — no hardcoded values in source)
SENTRY_DSN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# HubSpot
HUBSPOT_ACCESS_TOKEN=

# Amplitude
AMPLITUDE_API_KEY=

# Linear
LINEAR_API_KEY=
